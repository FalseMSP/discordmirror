# ── Twitch ─────────────────────────────────────────────────────────────────
TWITCH_TOKEN=oauth:YOUR_OAUTH_TOKEN
TWITCH_CLIENT_ID=YOUR_CLIENT_ID
TWITCH_BOT_NICK=your_bot_username
TWITCH_CHANNELS=channel1,channel2

# ── YouTube ────────────────────────────────────────────────────────────────
YT_API_KEY=YOUR_YOUTUBE_API_KEY
# Video ID of the current/upcoming live stream (for immediate chat session)
YT_VIDEO_ID=YOUR_LIVE_VIDEO_ID
# Channel ID — used by WebSub to subscribe to future streams automatically
# Find it at: youtube.com/channel/<this_id>  or via the API
YT_CHANNEL_ID=UC0b2v3Pm6rAyvbj_wE9ahHA

# ── WebSub / PubSubHubbub ──────────────────────────────────────────────────
# Set this to your publicly-reachable URL to enable push mode (recommended).
# Leave blank to fall back to polling.
#
# Option A — ngrok (easiest for local dev):
#   ngrok http 8080
#   Then paste the https URL below (no trailing slash)
#
# Option B — VPS / cloud:
#   Point a domain or IP to this machine on port 8080
#
WEBSUB_PUBLIC_URL=https://your-ngrok-or-domain.example.com
# A random secret shared with Google's hub for HMAC signature verification.
# Generate one with: python -c "import secrets; print(secrets.token_hex(32))"
WEBSUB_SECRET=skibidiyibidirizzilicookie
# Port the local callback server listens on
WEBSUB_PORT=8080
# Poll interval fallback (seconds) — only used when WebSub is not configured
YT_POLL_INTERVAL=8
